# ─────────────────────────────────────────────────────────────────────────────
# Conversational-For-LibreChat  ·  Environment Configuration
# Copy this file to .env and fill in your values.
# ─────────────────────────────────────────────────────────────────────────────

# ── LiveKit ──────────────────────────────────────────────────────────────────
# Get these from https://cloud.livekit.io  OR  your self-hosted LiveKit server
LIVEKIT_URL=ws://localhost:7880
LIVEKIT_API_KEY=devkey
LIVEKIT_API_SECRET=devsecret

# ── Deepgram STT ─────────────────────────────────────────────────────────────
DEEPGRAM_API_KEY=your_deepgram_api_key_here
# Nova-2 is recommended for best accuracy/latency balance
DEEPGRAM_MODEL=nova-2
DEEPGRAM_LANGUAGE=en-US
# Silence duration (ms) before transcript is finalised — 300–500 recommended
DEEPGRAM_ENDPOINTING_MS=400

# ── LLM (LibreChat / OpenAI-compatible) ──────────────────────────────────────
# Point at LibreChat's OpenAI-compat endpoint OR OpenAI directly
LLM_BASE_URL=http://localhost:3080/api
LLM_API_KEY=librechat_user_jwt_or_openai_key
LLM_MODEL=gpt-4o-mini
LLM_MAX_TOKENS=1024
LLM_TEMPERATURE=0.7
# System prompt injected for every voice session
LLM_SYSTEM_PROMPT=You are a helpful, concise voice assistant. Keep answers short and conversational.

# ── TTS Provider ─────────────────────────────────────────────────────────────
# "piper" | "openai" | "elevenlabs"
TTS_PROVIDER=openai

# Piper (local, free) — runs as a sidecar container
PIPER_URL=http://localhost:5000/synthesize
PIPER_VOICE=en_US-lessac-medium

# OpenAI TTS (low-latency, paid)
OPENAI_API_KEY=your_openai_api_key_here
OPENAI_TTS_VOICE=alloy
OPENAI_TTS_MODEL=tts-1

# ElevenLabs TTS (highest quality, paid)
ELEVENLABS_API_KEY=your_elevenlabs_api_key_here
ELEVENLABS_VOICE_ID=21m00Tcm4TlvDq8ikWAM
ELEVENLABS_MODEL=eleven_turbo_v2_5

# ── Fallback STT (Whisper) ───────────────────────────────────────────────────
# Activated automatically when Deepgram is unreachable
WHISPER_URL=http://localhost:9000/asr
WHISPER_MODEL=base

# ── Voice Bridge HTTP Server ─────────────────────────────────────────────────
PORT=8080
HOST=0.0.0.0
# Shared secret used to authenticate token-generation requests from LibreChat
BRIDGE_API_SECRET=change_me_in_production

# ── Audio ────────────────────────────────────────────────────────────────────
# PCM sample rate sent to STT (Deepgram expects 16 kHz)
STT_SAMPLE_RATE=16000
# Sample rate published back to LiveKit room (WebRTC standard)
PLAYBACK_SAMPLE_RATE=48000
# Silence padding added after VAD detects end-of-speech (ms)
VAD_SILENCE_PADDING_MS=300
# Target loudness for mic normalisation (dBFS, negative number)
MIC_NORMALISE_LUFS=-23

# ── Observability ────────────────────────────────────────────────────────────
LOG_LEVEL=info
# Set to "true" to emit structured JSON logs
LOG_JSON=false
# Prometheus metrics endpoint (empty = disabled)
METRICS_PORT=9090
